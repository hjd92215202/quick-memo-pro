{
  "manifest_version": 3,
  "name": "极简随手记 Pro",
  "version": "1.1.0",
  "description": "灵感闪现，随时记录。支持云同步、Markdown 导出及右键采集。",
  "permissions": [
    "contextMenus",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://*.firestore.googleapis.com/*",
    "https://*.firebase.google.com/*",
    "https://www.google-analytics.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}